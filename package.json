{
  "name": "gemini-exporter",
  "version": "1.0.0",
  "description": "Export all your Google Gemini conversations to Markdown, JSON, or HTML",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "clean": "rm -rf dist",
    "package": "npm run build && cd dist && zip -r ../gemini-exporter.zip ."
  },
  "dependencies": {
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.313",
    "@types/turndown": "^5.0.5",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.7.3",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  }
}
